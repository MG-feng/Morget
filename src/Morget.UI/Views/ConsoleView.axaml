<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Morget.UI.ViewModels"
             x:Class="Morget.UI.Views.ConsoleView"
             x:DataType="vm:ConsoleViewModel">

  <Grid Margin="24" RowDefinitions="Auto,*,Auto">
    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12">
      <TextBlock Text="Console" FontSize="32" FontWeight="Light" />
      <Border Background="#2d2d2d" CornerRadius="4" Padding="8,4" HorizontalAlignment="Left">
        <TextBlock Text="{Binding StatusText}" FontSize="14" Foreground="Green" />
      </Border>
      <ProgressBar IsVisible="{Binding IsLoading}" IsIndeterminate="True" Width="100" Height="4" VerticalAlignment="Center" />
    </StackPanel>

    <Border Grid.Row="1" Classes="card" Margin="0,12,0,0">
      <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <ItemsControl ItemsSource="{Binding LogEntries}" Margin="12">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding}" FontFamily="Consolas,Courier New,monospace" FontSize="12" Margin="0,2" TextWrapping="Wrap" />
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Border>

    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0" HorizontalAlignment="Right">
      <Button Content="Clear" Command="{Binding ClearLogCommand}" Padding="16,8" />
    </StackPanel>
  </Grid>
</UserControl>
